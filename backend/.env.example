# ============================================================
# File cau hinh mau. CACH DUNG:
#   cp .env.example .env
# roi mo .env dien thong tin that. File .env KHONG duoc commit len git.
# ============================================================

# ===== Gui OTP qua email =====
# false = gui mail that ; true = chi in OTP ra console (che do DEV)
MAIL_DEV_MODE=false

# --- Cau hinh SMTP Gmail ---
MAIL_HOST=smtp.gmail.com
# Gmail cua ban (nguoi gui)
MAIL_USERNAME=your_gmail@gmail.com
# "Mat khau ung dung" 16 ky tu cua Gmail (BO het dau cach). KHONG phai mat khau dang nhap.
MAIL_PASSWORD=your16charapppass
# PHAI trung voi MAIL_USERNAME (Gmail bat buoc nguoi gui = tai khoan da xac thuc)
MAIL_FROM=your_gmail@gmail.com

# ===== Dia chi frontend (CORS) =====
CORS_ORIGINS=http://192.168.211.131:3000

# ===== (Tuy chon) Ket noi DB — bo comment neu muon doi mac dinh =====
