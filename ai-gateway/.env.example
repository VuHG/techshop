# Cổng chạy AI Gateway
PORT=3001

# API key Google Gemini (free) — lấy tại https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Model Gemini. Nếu Google đổi/ngừng model, chỉ cần sửa dòng này.
# Gợi ý free tier: gemini-2.0-flash | gemini-2.5-flash | gemini-1.5-flash
GEMINI_MODEL=gemini-2.0-flash

# Origin frontend được phép gọi (phân tách bằng dấu phẩy)
CORS_ORIGINS=http://localhost:3000

# Timeout gọi Gemini (ms)
AI_TIMEOUT_MS=15000

# ===== RAG / Qdrant (tìm sản phẩm bằng ngữ nghĩa) =====
# ĐỂ TRỐNG = TẮT RAG (chatbot dùng danh sách top-40 như cũ).
# Bật: chạy Qdrant rồi điền URL, vd:  docker run -p 6333:6333 qdrant/qdrant
QDRANT_URL=
# Model tạo embedding của Gemini. Đổi model nhớ xóa collection cũ (khác số chiều).
EMBED_MODEL=gemini-embedding-001
# Số sản phẩm liên quan lấy ra mỗi câu hỏi
RAG_TOP_K=8
# Chu kỳ index lại (ms) — mặc định 30 phút
RAG_REINDEX_MS=1800000
