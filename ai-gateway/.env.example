# Cổng chạy AI Gateway
PORT=3001

# API key Groq (free) — lấy tại https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Model Groq. Nếu Groq đổi/ngừng model, chỉ cần sửa dòng này (xem model khả dụng ở console.groq.com).
GROQ_MODEL=llama-3.3-70b-versatile

# Origin frontend được phép gọi (phân tách bằng dấu phẩy)
CORS_ORIGINS=http://localhost:3000

# Timeout gọi Groq (ms)
AI_TIMEOUT_MS=15000
