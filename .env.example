# ============================================================
# Cấu hình cho docker compose. Dùng:  cp .env.example .env  rồi sửa.
# ============================================================

# ===== Địa chỉ PUBLIC (trình duyệt khách gọi tới) =====
# ĐỔI localhost thành IP/domain server thật, ví dụ 192.168.211.131.
# Phải nướng vào lúc build frontend nên đổi xong cần build lại frontend.
NEXT_PUBLIC_API_URL=http://localhost:8080/api
NEXT_PUBLIC_AI_URL=http://localhost:3001/api/ai
# CORS: đúng origin của frontend (không có /api ở cuối)
CORS_ORIGINS=http://localhost:3000

# ===== Postgres =====
POSTGRES_DB=techshop
POSTGRES_USER=techshop
POSTGRES_PASSWORD=techshop_dev_2026

# ===== Backend =====
SPRING_PROFILES_ACTIVE=dev
ADMIN_PHONE=0999999999
ADMIN_PASSWORD=Admin@123
# Gửi OTP: để MAIL_DEV_MODE=false + điền Gmail App Password để gửi mail thật.
MAIL_DEV_MODE=true
MAIL_HOST=smtp.gmail.com
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=

# ===== AI Gateway (chatbot Gemini + RAG Qdrant) =====
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
EMBED_MODEL=gemini-embedding-001

# ===== Cổng host — CHỈ đổi khi bị TRÙNG cổng trên máy =====
# Bỏ dấu # và đổi số bên trái. Ví dụ Postgres máy bạn đã chạy ở 5432 -> đặt 5433.
# Ba cổng postgres/redis/qdrant chỉ để truy cập từ ngoài; đổi KHÔNG ảnh hưởng app
# (các container nói chuyện nội bộ). Đổi xong chạy lại: docker compose up -d
#POSTGRES_HOST_PORT=5432
#REDIS_HOST_PORT=6379
#QDRANT_HOST_PORT=6333
# 3 cổng dưới là cổng TRÌNH DUYỆT gọi tới. Nếu đổi, phải sửa cho khớp:
#   FRONTEND_HOST_PORT -> địa chỉ mở web + CORS_ORIGINS
#   BACKEND_HOST_PORT  -> NEXT_PUBLIC_API_URL
#   AI_HOST_PORT       -> NEXT_PUBLIC_AI_URL
# rồi build lại frontend: docker compose up -d --build
#FRONTEND_HOST_PORT=3000
#BACKEND_HOST_PORT=8080
#AI_HOST_PORT=3001
